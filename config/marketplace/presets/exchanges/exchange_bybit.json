                  "watchdog": {
                    "retry_policy": {
                      "max_attempts": 3,
                      "base_delay": 0.75
                    },
                    "circuit_breaker": {
                      "failure_threshold": 4,
                      "recovery_time_seconds": 60
                    }
                  },
                  "native_adapter": {
                    "settings": {
                      "account_type": "unified"
                    }
                  }
                },
                "credentials": {
                  "key_id": "${BYBIT_LIVE_KEY}",
                  "secret": "${BYBIT_LIVE_SECRET}"
                }
              }
            }
          ]
        }
