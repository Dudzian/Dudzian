{
  "preset": {
    "name": "Gemini Connectivity",
    "strategies": [
      {
        "name": "gemini_connectivity",
        "engine": "grid_trading",
        "parameters": {
          "exchange": "GEMINI",
          "default_environment": "paper",
          "available_environments": [
            "paper",
            "testnet",
            "live"
          ]
        },
        "license_tier": "community",
        "risk_classes": [
          "infrastructure"
        ],
        "required_data": [
          "ohlcv"
        ],
        "tags": [
          "exchange",
          "gemini"
        ],
        "metadata": {
          "description": "Automatycznie wygenerowany preset środowisk dla giełdy Gemini.",
          "environments": [
            {
              "name": "paper",
              "description": "Paper trading dla Gemini (spot, fee 35 bps).",
              "config": {
                "description": "Paper trading dla Gemini (spot, fee 35 bps).",
                "exchange_manager": {
                  "mode": "paper",
                  "paper_variant": "spot",
                  "paper_initial_cash": 15000,
                  "paper_cash_asset": "USD",
                  "paper_fee_rate": 0.0035
                },
                "credentials": {
                  "key_id": null,
                  "secret": null
                }
              }
            },
            {
              "name": "testnet",
              "description": "Gemini sandbox API.",
              "config": {
                "description": "Gemini sandbox API.",
                "exchange_manager": {
                  "mode": "spot",
                  "testnet": true,
                  "failover": {
                    "enabled": true,
                    "failure_threshold": 1,
                    "cooldown_seconds": 60
                  },
                  "rate_limit_rules": [
                    {
                      "rate": 15,
                      "per": 1.0
                    },
                    {
                      "rate": 1200,
                      "per": 60.0
                    }
                  ]
                },
                "credentials": {
                  "key_id": "${GEMINI_SANDBOX_KEY}",
                  "secret": "${GEMINI_SANDBOX_SECRET}"
                }
              }
            },
            {
              "name": "live",
              "description": "Produkcyjny handel na Gemini.",
              "config": {
                "description": "Produkcyjny handel na Gemini.",
                "exchange_manager": {
                  "mode": "spot",
                  "testnet": false,
                  "watchdog": {
                    "retry_policy": {
                      "max_attempts": 3,
                      "base_delay": 1.2
                    }
                  },
                  "failover": {
                    "enabled": true,
                    "failure_threshold": 1,
                    "cooldown_seconds": 75
                  },
                  "rate_limit_rules": [
                    {
                      "rate": 15,
                      "per": 1.0
                    },
                    {
                      "rate": 1200,
                      "per": 60.0
                    }
                  ]
                },
                "credentials": {
                  "key_id": "${GEMINI_LIVE_KEY}",
                  "secret": "${GEMINI_LIVE_SECRET}"
                }
              }
            }
          ]
        }
      }
    ],
