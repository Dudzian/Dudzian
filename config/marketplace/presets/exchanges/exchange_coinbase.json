{
  "preset": {
    "name": "Coinbase Connectivity",
    "strategies": [
      {
        "name": "coinbase_connectivity",
        "engine": "grid_trading",
        "parameters": {
          "exchange": "COINBASE",
          "default_environment": "paper",
