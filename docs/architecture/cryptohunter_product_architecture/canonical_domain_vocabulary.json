  "deprecated_environment_aliases": [
    {
      "term": "demo",
      "current_meanings": [
        "frontend maps demo to TESTNET",
        "docs use demo→paper→live pipeline"
      ],
      "canonical_target": "deprecated alias requiring context-specific migration",
      "migration_rule": "Do not rewrite blindly; classify old Demo as fixture, PAPER simulation, or exchange TESTNET before migration",
      "evidence_paths": [
        "bot_core/runtime/frontend.py",
        "docs/architecture/desktop_shell_plan.md"
      ]
    },
    {
      "term": "sandbox",
      "current_meanings": [
        "adapter endpoint classification through testnet/sandbox helpers",
        "not a product-wide environment"
      ],
      "canonical_target": "adapter endpoint classification; public target TESTNET",
      "migration_rule": "Keep sandbox only in adapter endpoint metadata/migration; expose TESTNET publicly",
      "evidence_paths": [
        "bot_core/exchanges/manager.py",
        "config/environments/exchange_modes.yaml"
      ]
    },
    {
      "term": "production/prod",
      "current_meanings": [
        "frontend accepts prod/production as LIVE aliases"
      ],
      "canonical_target": "legacy alias LIVE only in migration layer",
      "migration_rule": "Reject outside migration/import normalization after future change",
      "evidence_paths": [
        "bot_core/runtime/frontend.py"
      ]
    },
    {
      "term": "primary",
      "current_meanings": [
        "frontend bootstrap adapter name",
        "live default_route fallback and journal fields primary_exchange"
      ],
      "canonical_target": "legacy route/account alias; not durable ID",
      "migration_rule": "Replace with ExchangeAccount/ExecutionRoute IDs in future migration",
      "evidence_paths": [
        "bot_core/runtime/frontend.py",
        "bot_core/execution/execution_service.py",
        "bot_core/runtime/journal.py"
      ]
    }
  ],
